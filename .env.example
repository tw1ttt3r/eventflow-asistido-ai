# Copia este archivo a `.env` y ajusta los valores locales.
# Variables con prefijo NG_APP_ se inyectan en build/serve vía `ng --define`.
# No commitees `.env` (está en .gitignore).

# API / app
NG_APP_API_URL=NG_APP_API_URL
NG_APP_APP_NAME=NG_APP_APP_NAME
NG_APP_API_KEY=NG_APP_API_KEY

# Appwrite (BaaS) — definir en .env; environment*.ts solo tienen cadenas vacías
NG_APP_APPWRITE_ENDPOINT=NG_APP_APPWRITE_ENDPOINT
NG_APP_APPWRITE_PROJECT_ID=NG_APP_APPWRITE_PROJECT_ID
NG_APP_APPWRITE_PROJECT_NAME=NG_APP_APPWRITE_PROJECT_NAME

# SonarCloud / SonarQube (solo local; no commitees el token)
SONAR_HOST_URL=SONAR_HOST_URL
SONAR_TOKEN=SONAR_TOKEN
