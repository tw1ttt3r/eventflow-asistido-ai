# Copia este archivo a `.env` y ajusta los valores locales.
# Variables con prefijo NG_APP_ se inyectan en build/serve vía `ng --define`.
# `production` se deriva del comando (serve=false, build=true); no va en `.env`.
# No commitees `.env` (está en .gitignore).

# API / app
NG_APP_API_URL=NG_APP_API_URL
NG_APP_APP_NAME=NG_APP_APP_NAME
NG_APP_API_KEY=NG_APP_API_KEY

# Appwrite (BaaS) — definir en .env; environment*.ts solo tienen cadenas vacías
NG_APP_APPWRITE_ENDPOINT=NG_APP_APPWRITE_ENDPOINT
NG_APP_APPWRITE_PROJECT_ID=NG_APP_APPWRITE_PROJECT_ID
NG_APP_APPWRITE_PROJECT_NAME=NG_APP_APPWRITE_PROJECT_NAME

# Desarrollo: `mockSessionUser: true` en environment.development.ts expone a Jane Doe (user-1)
# como sesión mock para probar vistas de organizador (p. ej. /events/1/attendees) sin Appwrite.

# SonarQube / SonarCloud
# SONAR_HOST_URL y SONAR_PROJECT_KEY se reutilizan en la app (alias → environment.sonar.*)
# SONAR_TOKEN solo scripts Node (pnpm sonar); no entra al bundle Angular
SONAR_HOST_URL=SONAR_HOST_URL
SONAR_TOKEN=SONAR_TOKEN
SONAR_PROJECT_KEY=SONAR_PROJECT_KEY
NG_APP_SONAR_HOST_URL=NG_APP_SONAR_HOST_URL
NG_APP_SONAR_PROJECT_KEY=NG_APP_SONAR_PROJECT_KEY
