{
  "name": "eventflow-asistido-ai",
  "version": "0.2.4",
  "scripts": {
    "ng": "ng",
    "start": "node scripts/with-env.mjs serve",
    "build": "node scripts/with-env.mjs build",
    "build:dev": "node scripts/with-env.mjs build --configuration development",
    "watch": "node scripts/with-env.mjs build --watch --configuration development",
    "test": "ng test",
    "prepare": "husky",
    "version:bump": "node scripts/version-bump.mjs",
    "version:major": "node scripts/version-bump.mjs --major",
    "version:dry-run": "node scripts/version-bump.mjs --dry-run",
    "test:coverage": "ng test --coverage --watch=false",
    "sonar": "node scripts/sonar.mjs",
    "quality": "node scripts/quality.mjs",
    "quality:coverage": "pnpm test:coverage",
    "env:sync": "node scripts/sync-env.mjs"
  },
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/service-worker": "^21.2.0",
    "appwrite": "^26.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.11",
    "@angular/cli": "^21.2.11",
    "@angular/compiler-cli": "^21.2.0",
    "@sonar/scan": "^4.3.6",
    "@tailwindcss/postcss": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.6",
    "dotenv": "^17.2.3",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
